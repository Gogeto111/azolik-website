{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "include": ["src/**", "*.ts", "*.tsx", "*.json", "*.md"],
    "ignore": [
      "dist",
      "node_modules",
      "e2e",
      "*.config.*",
      "*.d.ts",
      "playwright.config.ts",
      ".bolt",
      "tsconfig*.json",
      "vite.config.ts",
      "postcss.config.js",
      "tailwind.config.js",
      "eslint.config.js",
      "vercel.json"
    ],
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useKeyWithClickEvents": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn",
        "noMultipleSpacesInRegularExpressionLiterals": "error"
      },
      "correctness": {
        "noChildrenProp": "off",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error",
        "useTemplate": "error",
        "useNumberNamespace": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noConsoleLog": "warn",
        "noExplicitAny": "warn",
        "noFallthroughSwitchClause": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  },
  "organizeImports": {
    "enabled": true
  }
}
